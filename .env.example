# Social Media Manager - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# API bearer token for all authenticated requests (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SMM_API_TOKEN=change-me-to-a-random-token

# Dashboard login password
SMM_PASSWORD=change-me-to-a-strong-password

# CORS allowed origins (comma-separated)
SMM_CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# Timezone for scheduling (IANA format)
SMM_TIMEZONE=Europe/Warsaw

# YouTube OAuth redirect URI (must match Google Cloud Console)
SMM_YT_REDIRECT_URI=https://yourdomain.com/social-admin-v2/api/youtube/oauth/callback
